# Server
PORT=3000
NODE_ENV=development                # Set to "production" on Render/Railway
FRONTEND_URL=http://localhost:5173  # Production: your Vercel URL (e.g. https://nearly.vercel.app)

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nearly

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000  # Production: your Render URL (e.g. https://nearly-api.onrender.com)

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Admin Seed (one-time bootstrap)
ADMIN_SEED_SECRET=your-admin-seed-secret
